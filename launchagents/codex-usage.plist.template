<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  tmux-aibar Codex 사용량 갱신 LaunchAgent 템플릿.

  설치 (REPLACE 부분을 본인 경로로 치환 후 ~/Library/LaunchAgents/ 에 저장):
    sed "s|REPLACE_PLUGIN_DIR|$HOME/.tmux/plugins/tmux-aibar|g; s|REPLACE_USER|$USER|g" \
      codex-usage.plist.template \
      > ~/Library/LaunchAgents/com.tmux-aibar.codex-usage.plist

    launchctl bootstrap gui/$(id -u) \
      ~/Library/LaunchAgents/com.tmux-aibar.codex-usage.plist
    launchctl kickstart -k gui/$(id -u)/com.tmux-aibar.codex-usage
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tmux-aibar.codex-usage</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>REPLACE_PLUGIN_DIR/scripts/refresh-codex-usage.sh</string>
    </array>

    <key>StartInterval</key>
    <integer>60</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>REPLACE_PLUGIN_DIR/cache/codex-usage.log</string>

    <key>StandardErrorPath</key>
    <string>REPLACE_PLUGIN_DIR/cache/codex-usage.err</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/usr/bin:/bin:/usr/sbin:/sbin:/opt/homebrew/bin:/usr/local/bin</string>
        <key>HOME</key>
        <string>/Users/REPLACE_USER</string>
        <key>USER</key>
        <string>REPLACE_USER</string>
    </dict>
</dict>
</plist>
